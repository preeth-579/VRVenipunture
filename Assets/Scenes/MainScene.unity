  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '1.  Wash your hands in wash basin.

    2. Wear gloves from glove dispenser.

    3.
    Grab the cotton from cotton dispanser and dip it with alcohol.

    4. Grab the
    tronequet and place it around patient''s arm.

    5. Inserts the butterfly canulla
    exactly on the patient''s veins.

    6. Attach the collection tube at the butterfly
    canulla.

    7. The blood starts fill inside the collection tube. '
  m_isRightToLeft: 0
